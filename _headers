# Cloudflare Pages — Headers HTTP
# Documentación: https://developers.cloudflare.com/pages/configuration/headers/

# Headers globales de seguridad
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Caché agresiva para assets estáticos (1 año)
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# HTML: revalidar siempre para que los cambios se vean al instante
/*.html
  Cache-Control: public, max-age=0, must-revalidate
